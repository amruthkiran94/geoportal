{
  "port": 3020,

  "shareUrlPrefixes": {
    "s": {
      "service": "s3",
      "bucket": "terriajs-shares",
      "region": "us-east-1",
      "endpoint": "http://minio:9000",
      "forcePathStyle": true,
      "accessKeyId": "REPLACE_WITH_MINIO_ROOT_USER",
      "secretAccessKey": "REPLACE_WITH_MINIO_ROOT_PASSWORD",
      "keyLength": 8
    }
  },
  "newShareUrlPrefix": "s",

  "allowProxyFor": ["githubusercontent.com"]
}
